generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum PlanName {
  FREE
  STARTER
  PRO
}

enum GalleryStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ClientActivity {
  NOT_OPENED
  SELECTING
  SUBMITTED
}

enum PhotoStatus {
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum DownloadStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum SelectionWorkflow {
  IN_PROGRESS
  COMPLETED_BY_CLIENT
  IN_REVIEW
  EDITING
  DELIVERED
}

enum EditStatus {
  NONE
  EDITING
  FINAL_READY
}

enum DownloadType {
  NONE
  WATERMARKED
  FINAL_EDITED
  ORIGINALS
  SELECTED_ONLY
  FULL_GALLERY
}

enum WatermarkPosition {
  CENTER
  TOP_LEFT
  TOP_RIGHT
  BOTTOM_LEFT
  BOTTOM_RIGHT
}

enum GalleryEventType {
  GALLERY_OPENED
  CLIENT_REGISTERED
  PHOTO_SELECTED
  PHOTO_DESELECTED
  PHOTO_FAVORITED
  PHOTO_UNFAVORITED
  COMMENT_ADDED
  SELECTION_SUBMITTED
  FINAL_UPLOADED
  FINALS_READY
  DOWNLOAD_REQUESTED
}

// ── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String              @id @default(uuid())
  email        String              @unique
  auth0Sub     String?             @unique
  name         String
  passwordHash String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  profile      PhotographerProfile?
}

/// Subscription plan definition — rows seeded at deploy time
model Plan {
  id                   String              @id @default(uuid())
  name                 PlanName            @unique
  storageLimitGB       Int
  maxGalleries         Int?                // null = unlimited
  photoLimitPerGallery Int?                // null = unlimited
  createdAt            DateTime            @default(now())
  photographers        PhotographerProfile[]
}

model PhotographerProfile {
  id               String           @id @default(uuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan             @relation(fields: [planId], references: [id])
  businessName     String?
  storageLimitGB   Int              @default(5)
  storageUsedBytes BigInt           @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  galleries        Gallery[]
  folders          GalleryFolder[]
  presets          GalleryPreset[]
  watermarkPresets WatermarkPreset[]
}

model GalleryFolder {
  id             String              @id @default(uuid())
  photographerId String
  photographer   PhotographerProfile @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  name           String
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  galleries      Gallery[]

  @@index([photographerId])
}

model Gallery {
  id                 String              @id @default(uuid())
  photographerId     String
  photographer       PhotographerProfile @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  folderId           String?
  folder             GalleryFolder?      @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title              String
  subtitle           String?
  clientName         String
  clientEmail        String?
  status             GalleryStatus       @default(DRAFT)
  // Access
  shareToken         String              @unique @default(uuid())
  password           String?
  expiresAt          DateTime?
  // Client interaction
  allowSelection     Boolean             @default(true)
  allowFavorites     Boolean             @default(false)
  allowComments      Boolean             @default(false)
  requireClientInfo  Boolean             @default(false)
  // Downloads
  downloadEnabled    Boolean             @default(false)
  downloadType       DownloadType        @default(NONE)
  // Protection
  watermarkEnabled   Boolean             @default(true)
  watermarkPresetId  String?
  watermarkPreset    WatermarkPreset?    @relation(fields: [watermarkPresetId], references: [id], onDelete: SetNull)
  // Presentation
  coverPhotoId       String?
  coverStyle         String              @default("fullscreen")
  galleryLayout      String              @default("masonry")
  typographyStyle    String              @default("serif")
  colorTheme         String              @default("dark")
  eventDate          String?
  tags               String[]            @default([])
  // Activity
  clientActivity     ClientActivity      @default(NOT_OPENED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  photos             Photo[]
  sections           GallerySection[]
  selections         Selection[]
  downloads          Download[]
  galleryClients     GalleryClient[]
  activityEvents     GalleryActivityEvent[]
  favorites          Favorite[]
  comments           Comment[]

  @@index([photographerId])
  @@index([photographerId, folderId])
  @@index([status])
}

model GallerySection {
  id        String   @id @default(uuid())
  galleryId String
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  photos    Photo[]

  @@index([galleryId])
}

model GalleryClient {
  id             String     @id @default(uuid())
  galleryId      String
  gallery        Gallery    @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  name           String
  email          String
  accessToken    String     @unique @default(uuid())
  lastAccessedAt DateTime   @default(now())
  createdAt      DateTime   @default(now())
  selections     Selection[]
  favorites      Favorite[]
  comments       Comment[]

  @@unique([galleryId, email])
  @@index([galleryId])
}

model Photo {
  id             String          @id @default(uuid())
  galleryId      String
  gallery        Gallery         @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  sectionId      String?
  section        GallerySection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  filename       String
  originalKey    String          @unique
  previewKey     String?
  thumbnailKey   String?
  watermarkedKey String?
  mimeType       String
  sizeBytes      BigInt
  width          Int?
  height         Int?
  status         PhotoStatus     @default(UPLOADING)
  editStatus     EditStatus      @default(NONE)
  finalKey       String?
  sortOrder      Int             @default(0)
  labels                   String[]        @default([])
  appliedWatermarkPresetId String?
  createdAt                DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  selectionItems SelectionItem[]
  favorites      Favorite[]
  comments       Comment[]

  @@index([galleryId])
  @@index([galleryId, status])
  @@index([sectionId])
}

model Selection {
  id              String         @id @default(uuid())
  galleryId       String
  gallery         Gallery        @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryClientId String?
  galleryClient   GalleryClient? @relation(fields: [galleryClientId], references: [id], onDelete: SetNull)
  clientEmail     String?
  clientName      String?
  submittedAt     DateTime?
  workflowState   SelectionWorkflow @default(IN_PROGRESS)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           SelectionItem[]
  downloads       Download[]

  @@index([galleryId])
  @@index([galleryClientId])
}

model SelectionItem {
  id          String    @id @default(uuid())
  selectionId String
  selection   Selection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  photoId     String
  photo       Photo     @relation(fields: [photoId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([selectionId, photoId])
  @@index([photoId])
}

model Download {
  id          String         @id @default(uuid())
  galleryId   String
  gallery     Gallery        @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  selectionId String?
  selection   Selection?     @relation(fields: [selectionId], references: [id])
  status      DownloadStatus @default(PENDING)
  zipKey      String?
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())

  @@index([galleryId])
  @@index([selectionId])
}

model GalleryPreset {
  id                String              @id @default(uuid())
  photographerId    String
  photographer      PhotographerProfile @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  name              String
  isDefault         Boolean             @default(false)
  // Client interaction
  allowSelection    Boolean             @default(true)
  allowFavorites    Boolean             @default(false)
  allowComments     Boolean             @default(false)
  requireClientInfo Boolean             @default(false)
  // Downloads
  downloadEnabled   Boolean             @default(false)
  downloadType      DownloadType        @default(NONE)
  // Protection
  watermarkEnabled  Boolean             @default(true)
  // Access
  expiresInDays     Int?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([photographerId])
}

model GalleryActivityEvent {
  id        String           @id @default(uuid())
  galleryId String
  gallery   Gallery          @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  eventType GalleryEventType
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([galleryId])
  @@index([galleryId, eventType])
}

model Favorite {
  id              String        @id @default(uuid())
  galleryId       String
  gallery         Gallery       @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryClientId String
  galleryClient   GalleryClient @relation(fields: [galleryClientId], references: [id], onDelete: Cascade)
  photoId         String
  photo           Photo         @relation(fields: [photoId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([galleryClientId, photoId])
  @@index([galleryId])
  @@index([galleryClientId])
}

model Comment {
  id              String        @id @default(uuid())
  galleryId       String
  gallery         Gallery       @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  galleryClientId String
  galleryClient   GalleryClient @relation(fields: [galleryClientId], references: [id], onDelete: Cascade)
  photoId         String?
  photo           Photo?        @relation(fields: [photoId], references: [id], onDelete: SetNull)
  body            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([galleryId])
  @@index([galleryClientId])
  @@index([galleryClientId, photoId])
}

model WatermarkPreset {
  id             String              @id @default(uuid())
  photographerId String
  photographer   PhotographerProfile @relation(fields: [photographerId], references: [id], onDelete: Cascade)
  name           String
  imageKey       String
  position       WatermarkPosition   @default(CENTER)
  sizePct        Int                 @default(20)
  opacity        Int                 @default(40)
  isDefault      Boolean             @default(false)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  galleries      Gallery[]

  @@index([photographerId])
}
